{
  "name": "pack-test",
  "version": "1.0.0",
  "private": true,
  "description": "前端构建工具对比实验室 - Webpack5 / Vite / Rollup / Rolldown / Rspack",
  "scripts": {
    "generate": "tsx scripts/generate.ts",
    "build:webpack": "webpack --config configs/webpack/webpack.config.ts",
    "dev:webpack": "webpack serve --config configs/webpack/webpack.config.ts",
    "build:vite": "vite build --config configs/vite/vite.config.ts",
    "dev:vite": "vite --config configs/vite/vite.config.ts",
    "build:rollup": "rollup -c configs/rollup/rollup.config.ts --configPlugin typescript",
    "build:rolldown": "rolldown -c configs/rolldown/rolldown.config.mjs",
    "build:rspack": "rspack build --config configs/rspack/rspack.config.ts",
    "dev:rspack": "rspack serve --config configs/rspack/rspack.config.ts",
    "bench": "tsx scripts/bench.ts",
    "bench:clean": "rm -rf configs/*/node_modules/.cache .tsbuildinfo"
  },
  "dependencies": {
    "antd": "^5.21.0",
    "axios": "^1.7.7",
    "dayjs": "^1.11.13",
    "echarts": "^5.5.1",
    "echarts-for-react": "^3.0.2",
    "lodash-es": "^4.17.21",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-replace": "^6.0.1",
    "@rollup/plugin-typescript": "^12.1.0",
    "@rollup/plugin-url": "^8.0.2",
    "@rspack/cli": "^1.1.0",
    "@rspack/core": "^1.1.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "css-loader": "^7.1.2",
    "html-webpack-plugin": "^5.6.0",
    "mini-css-extract-plugin": "^2.9.1",
    "postcss": "^8.4.47",
    "postcss-modules": "^6.0.0",
    "rolldown": "^0.15.1",
    "rollup": "^4.24.0",
    "rollup-plugin-postcss": "^4.0.2",
    "style-loader": "^4.0.0",
    "swc-loader": "^0.2.6",
    "terser-webpack-plugin": "^5.3.10",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tslib": "^2.7.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "webpack": "^5.95.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.1.0"
  }
}
